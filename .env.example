# HTTP port (Docker/Dokploy default: 3055)
PORT=3055

# Password for admin panel (/admin/login)
ADMIN_PASSWORD=change-me

# SQLite docs database path (relative to project root)
# Default: ./data/docs.sqlite
# In Docker: /app/data/docs.sqlite (volume portal_data)
DOCS_DB_PATH=./data/docs.sqlite

# 1C UPP gateway base URL for local API examples and curl
GATEWAY_BASE_URL=https://your-gateway.example.com

# 1C UPP MCP endpoint for availability checks in the portal UI
MCP_URL=https://mcp.avgst.ru/mcp
