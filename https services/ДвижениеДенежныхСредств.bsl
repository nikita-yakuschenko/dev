// HTTP-сервис cashflows, метод GetCashFlows. URL: /hs/cashflows/get
// Ведомость по денежным средствам (остатки и обороты).
// Источник: РегистрНакопления.ДенежныеСредства.ОстаткиИОбороты.
// В JSON у каждой строки: Организация, СчетКасса, ВидДенежныхСредств, Банк, ВидСчета, Валюта, Закрыт,
// НачальныйОстаток, Приход, Расход, КонечныйОстаток; при totals=true - строка Итог.
// Параметры: from, to; date; org, account, cash, bank; mgmt (true - суммы в упр. учете); totals.

Функция GetCashFlows(Запрос) Экспорт
	Возврат GetCashFlows_Impl(Запрос);
КонецФункции

Функция ПолучитьСтроковойПараметр(Запрос, ИмяПараметра)
	Значение = "";

	Попытка
		Значение = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить(ИмяПараметра)));
	Исключение
		Значение = "";
	КонецПопытки;

	Если Значение = "" Тогда
		Попытка
			Значение = СокрЛП(Строка(Запрос.ПараметрыURL[ИмяПараметра]));
		Исключение
			Значение = "";
		КонецПопытки;
	КонецЕсли;

	Возврат Значение;
КонецФункции

Функция ПреобразоватьВБулево(СтрокаЛог)
	Если ПустаяСтрока(СтрокаЛог) Тогда
		Возврат Ложь;
	КонецЕсли;

	Стр = ВРег(СокрЛП(СтрокаЛог));
	Возврат Стр = "1" Или Стр = "TRUE" Или Стр = "YES" Или Стр = "ДА";
КонецФункции

Функция РазобратьДатуСтрокой(ЗначДата, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня)
	Результат = Новый Структура;
	Результат.Вставить("Ок", Ложь);
	Результат.Вставить("Г", "");
	Результат.Вставить("М", "");
	Результат.Вставить("Д", "");

	Если Не ЗначениеЗаполнено(ЗначДата) Тогда
		Возврат Результат;
	КонецЕсли;

	Г = "";
	М = "";
	Д = "";
	ЧастиТочка = СтрРазделить(ЗначДата, ".", Ложь);
	ЧастиДефис = СтрРазделить(ЗначДата, "-", Ложь);

	Если ЧастиТочка.Количество() = КолЧастейДаты Тогда
		Д = ЧастиТочка[0];
		М = ЧастиТочка[1];
		Г = ЧастиТочка[2];
	ИначеЕсли ЧастиДефис.Количество() = КолЧастейДаты Тогда
		Если СтрДлина(СокрЛП(ЧастиДефис[0])) = ДлинаГода Тогда
			Г = ЧастиДефис[0];
			М = ЧастиДефис[1];
			Д = ЧастиДефис[2];
		Иначе
			Д = ЧастиДефис[0];
			М = ЧастиДефис[1];
			Г = ЧастиДефис[2];
		КонецЕсли;
	Иначе
		Возврат Результат;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Г) Тогда
		Возврат Результат;
	КонецЕсли;

	Пока СтрДлина(Г) < ДлинаГода Цикл
		Г = "0" + Г;
	КонецЦикла;
	Пока СтрДлина(М) < ДлинаМесяца Цикл
		М = "0" + М;
	КонецЦикла;
	Пока СтрДлина(Д) < ДлинаДня Цикл
		Д = "0" + Д;
	КонецЦикла;

	Результат.Ок = Истина;
	Результат.Г = Г;
	Результат.М = М;
	Результат.Д = Д;
	Возврат Результат;
КонецФункции

Функция РазобратьПериодFromTo(ЗначFrom, ЗначTo, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок)
	ПериодРезультат = Новый Структура;
	ПериодРезультат.Вставить("ИспользоватьПериод", Ложь);
	ПериодРезультат.Вставить("ДатаНачала", Дата(1, 1, 1));
	ПериодРезультат.Вставить("ДатаОкончания", Дата(1, 1, 1));

	Если Не ЗначениеЗаполнено(ЗначFrom) Или Не ЗначениеЗаполнено(ЗначTo) Тогда
		Возврат ПериодРезультат;
	КонецЕсли;

	П1 = РазобратьДатуСтрокой(ЗначFrom, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
	П2 = РазобратьДатуСтрокой(ЗначTo, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
	Если П1.Ок И П2.Ок Тогда
		ПериодРезультат.ДатаНачала = Дата(П1.Г + П1.М + П1.Д + "000000");
		ПериодРезультат.ДатаОкончания = КонецДня(Дата(П2.Г + П2.М + П2.Д + "000000"));
		ПериодРезультат.ИспользоватьПериод = Истина;
	Иначе
		МассивОшибок.Добавить("Некорректный формат from/to: " + ЗначFrom + " / " + ЗначTo);
	КонецЕсли;

	Возврат ПериодРезультат;
КонецФункции

Функция СтрокаДатыДокумента(ДатаДокумента)
	ФорматДаты = "ДФ=dd.MM.yyyy";

	Если Не ЗначениеЗаполнено(ДатаДокумента) Тогда
		Возврат "";
	КонецЕсли;

	Возврат Формат(ДатаДокумента, ФорматДаты);
КонецФункции

Функция СовпадаетПостФильтр(ЗначениеПоля, Подстрока)
	Возврат СтрНайти(ВРег(Строка(ЗначениеПоля)), ВРег(Подстрока)) > 0;
КонецФункции

Функция ПроходитСтроковыйПостФильтр(ИспользоватьФильтр, ЗначениеПоля, Подстрока)
	Если Не ИспользоватьФильтр Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат СовпадаетПостФильтр(ЗначениеПоля, Подстрока);
КонецФункции

Функция СобратьФильтры(Запрос, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок)
	Фильтры = Новый Структура;

	ЗначFrom = ПолучитьСтроковойПараметр(Запрос, "from");
	ЗначTo = ПолучитьСтроковойПараметр(Запрос, "to");
	ПериодРезультат = РазобратьПериодFromTo(
		ЗначFrom,
		ЗначTo,
		КолЧастейДаты,
		ДлинаГода,
		ДлинаМесяца,
		ДлинаДня,
		МассивОшибок);

	ИспользоватьФильтрДата = Ложь;
	ДатаФильтр = Дата(1, 1, 1);
	ДатаФильтрКонец = Дата(1, 1, 1);
	ЗначDate = ПолучитьСтроковойПараметр(Запрос, "date");
	Если ЗначDate <> "" Тогда
		П = РазобратьДатуСтрокой(ЗначDate, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
		Если П.Ок Тогда
			ДатаФильтр = Дата(П.Г + П.М + П.Д + "000000");
			ДатаФильтрКонец = КонецДня(ДатаФильтр);
			ИспользоватьФильтрДата = Истина;
		Иначе
			МассивОшибок.Добавить("Некорректный параметр date: " + ЗначDate);
		КонецЕсли;
	КонецЕсли;

	Если ИспользоватьФильтрДата Тогда
		ПериодРезультат.ДатаНачала = ДатаФильтр;
		ПериодРезультат.ДатаОкончания = ДатаФильтрКонец;
		ПериодРезультат.ИспользоватьПериод = Истина;
	Иначе
		Если Не ПериодРезультат.ИспользоватьПериод Тогда
			МассивОшибок.Добавить("Укажите период: from и to, либо date");
		КонецЕсли;
	КонецЕсли;

	Фильтры.Вставить("ИспользоватьПериод", ПериодРезультат.ИспользоватьПериод);
	Фильтры.Вставить("ДатаНачала", ПериодРезультат.ДатаНачала);
	Фильтры.Вставить("ДатаОкончания", ПериодРезультат.ДатаОкончания);
	Фильтры.Вставить("ПериодС", СтрокаДатыДокумента(ПериодРезультат.ДатаНачала));
	Фильтры.Вставить("ПериодПо", СтрокаДатыДокумента(ПериодРезультат.ДатаОкончания));

	ЗначOrg = ПолучитьСтроковойПараметр(Запрос, "org");
	Фильтры.Вставить("ИспользоватьФильтрОрганизация", ЗначOrg <> "");
	Фильтры.Вставить("ПодстрокаОрганизация", ЗначOrg);

	ЗначAccount = ПолучитьСтроковойПараметр(Запрос, "account");
	Фильтры.Вставить("ИспользоватьФильтрСчет", ЗначAccount <> "");
	Фильтры.Вставить("ПодстрокаСчет", ЗначAccount);

	ЗначCash = ПолучитьСтроковойПараметр(Запрос, "cash");
	Фильтры.Вставить("ИспользоватьФильтрКасса", ЗначCash <> "");
	Фильтры.Вставить("ПодстрокаКасса", ЗначCash);

	ЗначBank = ПолучитьСтроковойПараметр(Запрос, "bank");
	Фильтры.Вставить("ИспользоватьФильтрБанк", ЗначBank <> "");
	Фильтры.Вставить("ПодстрокаБанк", ЗначBank);

	ЗначMgmt = ПолучитьСтроковойПараметр(Запрос, "mgmt");
	Фильтры.Вставить("УпрУчет", ПреобразоватьВБулево(ЗначMgmt));

	ЗначTotals = ПолучитьСтроковойПараметр(Запрос, "totals");
	Фильтры.Вставить("ДобавитьИтог", ПреобразоватьВБулево(ЗначTotals));

	Возврат Фильтры;
КонецФункции

Функция ПроходитПостФильтры(Выборка, Фильтры)
	Если Не ПроходитСтроковыйПостФильтр(
		Фильтры.ИспользоватьФильтрОрганизация,
		Выборка.Организация,
		Фильтры.ПодстрокаОрганизация) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрСчет
		И Не СовпадаетПостФильтр(Выборка.СчетКасса, Фильтры.ПодстрокаСчет) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрКасса
		И Не СовпадаетПостФильтр(Выборка.СчетКасса, Фильтры.ПодстрокаКасса) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Не ПроходитСтроковыйПостФильтр(
		Фильтры.ИспользоватьФильтрБанк,
		Выборка.Банк,
		Фильтры.ПодстрокаБанк) Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Истина;
КонецФункции

Функция ТекстЗапросаОстаткиИОбороты(УпрУчет)
	Если УпрУчет Тогда
		Возврат
		"ВЫБРАТЬ
		|	ДС.Организация КАК Организация,
		|	ДС.БанковскийСчетКасса КАК БанковскийСчетКасса,
		|	ДС.ВидДенежныхСредств КАК ВидДенежныхСредств,
		|	ДС.СуммаУпрНачальныйОстаток КАК НачальныйОстаток,
		|	ДС.СуммаУпрПриход КАК Приход,
		|	ДС.СуммаУпрРасход КАК Расход,
		|	ДС.СуммаУпрКонечныйОстаток КАК КонечныйОстаток
		|ПОМЕСТИТЬ ВТДенежныеСредства
		|ИЗ
		|	РегистрНакопления.ДенежныеСредства.ОстаткиИОбороты(&ДатаНачала, &ДатаОкончания, , , ) КАК ДС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПРЕДСТАВЛЕНИЕ(ВТ.Организация) КАК Организация,
		|	ПРЕДСТАВЛЕНИЕ(ВТ.БанковскийСчетКасса) КАК СчетКасса,
		|	ПРЕДСТАВЛЕНИЕ(ВТ.ВидДенежныхСредств) КАК ВидДенежныхСредств,
		|	ПРЕДСТАВЛЕНИЕ(БС.Банк) КАК Банк,
		|	БС.ВидСчета КАК ВидСчета,
		|	ПРЕДСТАВЛЕНИЕ(БС.ВалютаДенежныхСредств) КАК ВалютаБанк,
		|	ПРЕДСТАВЛЕНИЕ(Кассы.ВалютаДенежныхСредств) КАК ВалютаКасса,
		|	БС.ДатаЗакрытия КАК ДатаЗакрытияСчета,
		|	ВТ.НачальныйОстаток КАК НачальныйОстаток,
		|	ВТ.Приход КАК Приход,
		|	ВТ.Расход КАК Расход,
		|	ВТ.КонечныйОстаток КАК КонечныйОстаток
		|ИЗ
		|	ВТДенежныеСредства КАК ВТ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БС
		|		ПО ВТ.БанковскийСчетКасса = БС.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Кассы КАК Кассы
		|		ПО ВТ.БанковскийСчетКасса = Кассы.Ссылка
		|УПОРЯДОЧИТЬ ПО
		|	Организация,
		|	СчетКасса";
	КонецЕсли;

	Возврат
	"ВЫБРАТЬ
	|	ДС.Организация КАК Организация,
	|	ДС.БанковскийСчетКасса КАК БанковскийСчетКасса,
	|	ДС.ВидДенежныхСредств КАК ВидДенежныхСредств,
	|	ДС.СуммаНачальныйОстаток КАК НачальныйОстаток,
	|	ДС.СуммаПриход КАК Приход,
	|	ДС.СуммаРасход КАК Расход,
	|	ДС.СуммаКонечныйОстаток КАК КонечныйОстаток
	|ПОМЕСТИТЬ ВТДенежныеСредства
	|ИЗ
	|	РегистрНакопления.ДенежныеСредства.ОстаткиИОбороты(&ДатаНачала, &ДатаОкончания, , , ) КАК ДС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(ВТ.Организация) КАК Организация,
	|	ПРЕДСТАВЛЕНИЕ(ВТ.БанковскийСчетКасса) КАК СчетКасса,
	|	ПРЕДСТАВЛЕНИЕ(ВТ.ВидДенежныхСредств) КАК ВидДенежныхСредств,
	|	ПРЕДСТАВЛЕНИЕ(БС.Банк) КАК Банк,
	|	БС.ВидСчета КАК ВидСчета,
	|	ПРЕДСТАВЛЕНИЕ(БС.ВалютаДенежныхСредств) КАК ВалютаБанк,
	|	ПРЕДСТАВЛЕНИЕ(Кассы.ВалютаДенежныхСредств) КАК ВалютаКасса,
	|	БС.ДатаЗакрытия КАК ДатаЗакрытияСчета,
	|	ВТ.НачальныйОстаток КАК НачальныйОстаток,
	|	ВТ.Приход КАК Приход,
	|	ВТ.Расход КАК Расход,
	|	ВТ.КонечныйОстаток КАК КонечныйОстаток
	|ИЗ
	|	ВТДенежныеСредства КАК ВТ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БС
	|		ПО ВТ.БанковскийСчетКасса = БС.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Кассы КАК Кассы
	|		ПО ВТ.БанковскийСчетКасса = Кассы.Ссылка
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	СчетКасса";
КонецФункции

Функция ПолучитьВыборкуДенежныхСредств(Фильтры)
	ЗапросБД = Новый Запрос;
	ЗапросБД.Текст = ТекстЗапросаОстаткиИОбороты(Фильтры.УпрУчет);
	ЗапросБД.УстановитьПараметр("ДатаНачала", Фильтры.ДатаНачала);
	ЗапросБД.УстановитьПараметр("ДатаОкончания", Фильтры.ДатаОкончания);

	Возврат ЗапросБД.Выполнить().Выбрать();
КонецФункции

Функция СуммаДляОтвета(ЗначениеСуммы)
	Если ПустаяСтрока(Строка(ЗначениеСуммы)) Или ЗначениеСуммы = Неопределено Тогда
		Возврат 0;
	КонецЕсли;

	Возврат ЗначениеСуммы;
КонецФункции

Функция ТекстПоляИлиПусто(Значение)
	Если Не ЗначениеЗаполнено(Значение) Тогда
		Возврат "";
	КонецЕсли;

	Возврат Значение;
КонецФункции

Функция ВалютаИзВыборки(Выборка)
	ВалютаБанк = ТекстПоляИлиПусто(Выборка.ВалютаБанк);
	Если ВалютаБанк <> "" Тогда
		Возврат ВалютаБанк;
	КонецЕсли;

	Возврат ТекстПоляИлиПусто(Выборка.ВалютаКасса);
КонецФункции

Функция СчетЗакрытИзВыборки(Выборка)
	Возврат ЗначениеЗаполнено(Выборка.ДатаЗакрытияСчета);
КонецФункции

Функция СформироватьСтрокуВедомости(Выборка, Фильтры)
	СтрокаДанных = Новый Структура;
	СтрокаДанных.Вставить("Итог", Ложь);
	СтрокаДанных.Вставить("ПериодС", Фильтры.ПериодС);
	СтрокаДанных.Вставить("ПериодПо", Фильтры.ПериодПо);
	СтрокаДанных.Вставить("Организация", ТекстПоляИлиПусто(Выборка.Организация));
	СтрокаДанных.Вставить("СчетКасса", ТекстПоляИлиПусто(Выборка.СчетКасса));
	СтрокаДанных.Вставить("ВидДенежныхСредств", ТекстПоляИлиПусто(Выборка.ВидДенежныхСредств));
	СтрокаДанных.Вставить("Банк", ТекстПоляИлиПусто(Выборка.Банк));
	СтрокаДанных.Вставить("ВидСчета", ТекстПоляИлиПусто(Выборка.ВидСчета));
	СтрокаДанных.Вставить("Валюта", ВалютаИзВыборки(Выборка));
	СтрокаДанных.Вставить("Закрыт", СчетЗакрытИзВыборки(Выборка));
	СтрокаДанных.Вставить("НачальныйОстаток", СуммаДляОтвета(Выборка.НачальныйОстаток));
	СтрокаДанных.Вставить("Приход", СуммаДляОтвета(Выборка.Приход));
	СтрокаДанных.Вставить("Расход", СуммаДляОтвета(Выборка.Расход));
	СтрокаДанных.Вставить("КонечныйОстаток", СуммаДляОтвета(Выборка.КонечныйОстаток));
	СтрокаДанных.Вставить("УпрУчет", Фильтры.УпрУчет);

	Возврат СтрокаДанных;
КонецФункции

Функция СформироватьСтрокуИтога(Фильтры, ИтогНачало, ИтогПриход, ИтогРасход, ИтогКонец)
	ТекстИтог = "Итог";
	СтрокаИтог = Новый Структура;
	СтрокаИтог.Вставить("Итог", Истина);
	СтрокаИтог.Вставить("ПериодС", Фильтры.ПериодС);
	СтрокаИтог.Вставить("ПериодПо", Фильтры.ПериодПо);
	СтрокаИтог.Вставить("Организация", "");
	СтрокаИтог.Вставить("СчетКасса", ТекстИтог);
	СтрокаИтог.Вставить("ВидДенежныхСредств", "");
	СтрокаИтог.Вставить("Банк", "");
	СтрокаИтог.Вставить("ВидСчета", "");
	СтрокаИтог.Вставить("Валюта", "");
	СтрокаИтог.Вставить("Закрыт", Ложь);
	СтрокаИтог.Вставить("НачальныйОстаток", ИтогНачало);
	СтрокаИтог.Вставить("Приход", ИтогПриход);
	СтрокаИтог.Вставить("Расход", ИтогРасход);
	СтрокаИтог.Вставить("КонечныйОстаток", ИтогКонец);
	СтрокаИтог.Вставить("УпрУчет", Фильтры.УпрУчет);

	Возврат СтрокаИтог;
КонецФункции

Функция СтрокаСериализуетсяВJSON(СтрокаДанных)
	Попытка
		ТестоваяЗаписьJSON = Новый ЗаписьJSON;
		ТестоваяЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ТестоваяЗаписьJSON, СтрокаДанных);
		ТестоваяЗаписьJSON.Закрыть();
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
КонецФункции

Функция СоздатьУспешныйОтвет(МассивСтрок, МассивОшибок)
	HTTPСтатусУспеха = 200;
	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data", МассивСтрок);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	JSON = Новый ЗаписьJSON;
	JSON.УстановитьСтроку();
	ЗаписатьJSON(JSON, ИтоговыйРезультат);
	JSONСтрока = JSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(HTTPСтатусУспеха);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(JSONСтрока);
	Возврат Ответ;
КонецФункции

Функция СоздатьОтветОшибки(ТекстОшибки)
	HTTPСтатусВнутренняяОшибкаСервера = 500;
	ДанныеОшибки = Новый Структура("error", ТекстОшибки);
	JSONОшибки = Новый ЗаписьJSON;
	JSONОшибки.УстановитьСтроку();
	ЗаписатьJSON(JSONОшибки, ДанныеОшибки);

	Ответ = Новый HTTPСервисОтвет(HTTPСтатусВнутренняяОшибкаСервера);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
	Возврат Ответ;
КонецФункции

Функция GetCashFlows_Impl(Запрос)
	МассивСтрок = Новый Массив;
	МассивОшибок = Новый Массив;
	КолЧастейДаты = СтрДлина("000");
	ДлинаГода = СтрДлина("0000");
	ДлинаМесяца = СтрДлина("00");
	ДлинаДня = СтрДлина("00");

	Попытка
		Фильтры = СобратьФильтры(Запрос, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок);

		Если Не Фильтры.ИспользоватьПериод Тогда
			Возврат СоздатьУспешныйОтвет(МассивСтрок, МассивОшибок);
		КонецЕсли;

		Выборка = ПолучитьВыборкуДенежныхСредств(Фильтры);
		ИтогНачало = 0;
		ИтогПриход = 0;
		ИтогРасход = 0;
		ИтогКонец = 0;

		Пока Выборка.Следующий() Цикл
			Если Не ПроходитПостФильтры(Выборка, Фильтры) Тогда
				Продолжить;
			КонецЕсли;

			СтрокаДанных = СформироватьСтрокуВедомости(Выборка, Фильтры);
			Если СтрокаСериализуетсяВJSON(СтрокаДанных) Тогда
				МассивСтрок.Добавить(СтрокаДанных);
				ИтогНачало = ИтогНачало + СтрокаДанных.НачальныйОстаток;
				ИтогПриход = ИтогПриход + СтрокаДанных.Приход;
				ИтогРасход = ИтогРасход + СтрокаДанных.Расход;
				ИтогКонец = ИтогКонец + СтрокаДанных.КонечныйОстаток;
			Иначе
				ТекстСчета = СтрокаДанных.СчетКасса;
				МассивОшибок.Добавить("Ошибка сериализации строки: " + ТекстСчета);
			КонецЕсли;
		КонецЦикла;

		Если Фильтры.ДобавитьИтог И МассивСтрок.Количество() > 0 Тогда
			СтрокаИтог = СформироватьСтрокуИтога(Фильтры, ИтогНачало, ИтогПриход, ИтогРасход, ИтогКонец);
			Если СтрокаСериализуетсяВJSON(СтрокаИтог) Тогда
				МассивСтрок.Добавить(СтрокаИтог);
			КонецЕсли;
		КонецЕсли;

		Возврат СоздатьУспешныйОтвет(МассивСтрок, МассивОшибок);
	Исключение
		Возврат СоздатьОтветОшибки(ОписаниеОшибки());
	КонецПопытки;
КонецФункции
