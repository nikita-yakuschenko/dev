// HTTP-сервис stockbalances, метод GetStockBalances. URL: /hs/stockbalances/get
// Стоимость остатков номенклатуры на складах.
// Источник: РегистрНакопления.ПартииТоваровНаСкладах.Остатки.
// JSON: data - номенклатура с массивом Остатки; errors - ошибки парсинга и сериализации.
// Параметры: code, name, warehouse, date, full.

Функция GetStockBalances(Запрос) Экспорт
	Возврат GetStockBalances_Impl(Запрос);
КонецФункции

Функция ПолучитьСтроковойПараметр(Запрос, ИмяПараметра)
	Значение = "";

	Попытка
		Значение = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить(ИмяПараметра)));
	Исключение
		Значение = "";
	КонецПопытки;

	Если Значение = "" Тогда
		Попытка
			Значение = СокрЛП(Строка(Запрос.ПараметрыURL[ИмяПараметра]));
		Исключение
			Значение = "";
		КонецПопытки;
	КонецЕсли;

	Возврат Значение;
КонецФункции

Функция ПреобразоватьВБулево(СтрокаЛог)
	Если ПустаяСтрока(СтрокаЛог) Тогда
		Возврат Ложь;
	КонецЕсли;

	Стр = ВРег(СокрЛП(СтрокаЛог));
	Возврат Стр = "1" Или Стр = "TRUE" Или Стр = "YES" Или Стр = "ДА";
КонецФункции

Функция РазобратьДатуСтрокой(ЗначДата, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня)
	Результат = Новый Структура;
	Результат.Вставить("Ок", Ложь);
	Результат.Вставить("Г", "");
	Результат.Вставить("М", "");
	Результат.Вставить("Д", "");

	Если Не ЗначениеЗаполнено(ЗначДата) Тогда
		Возврат Результат;
	КонецЕсли;

	Г = "";
	М = "";
	Д = "";
	ЧастиТочка = СтрРазделить(ЗначДата, ".", Ложь);
	ЧастиДефис = СтрРазделить(ЗначДата, "-", Ложь);

	Если ЧастиТочка.Количество() = КолЧастейДаты Тогда
		Д = ЧастиТочка[0];
		М = ЧастиТочка[1];
		Г = ЧастиТочка[2];
	ИначеЕсли ЧастиДефис.Количество() = КолЧастейДаты Тогда
		Если СтрДлина(СокрЛП(ЧастиДефис[0])) = ДлинаГода Тогда
			Г = ЧастиДефис[0];
			М = ЧастиДефис[1];
			Д = ЧастиДефис[2];
		Иначе
			Д = ЧастиДефис[0];
			М = ЧастиДефис[1];
			Г = ЧастиДефис[2];
		КонецЕсли;
	Иначе
		Возврат Результат;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Г) Тогда
		Возврат Результат;
	КонецЕсли;

	Пока СтрДлина(Г) < ДлинаГода Цикл
		Г = "0" + Г;
	КонецЦикла;
	Пока СтрДлина(М) < ДлинаМесяца Цикл
		М = "0" + М;
	КонецЦикла;
	Пока СтрДлина(Д) < ДлинаДня Цикл
		Д = "0" + Д;
	КонецЦикла;

	Результат.Ок = Истина;
	Результат.Г = Г;
	Результат.М = М;
	Результат.Д = Д;
	Возврат Результат;
КонецФункции

Функция ДатаИзРазбора(ЧастиДаты)
	Возврат Дата(ЧастиДаты.Г + ЧастиДаты.М + ЧастиДаты.Д + "000000");
КонецФункции

Функция СтрокаДатыДокумента(ДатаДокумента)
	ФорматДаты = "ДФ=dd.MM.yyyy";

	Если Не ЗначениеЗаполнено(ДатаДокумента) Тогда
		Возврат "";
	КонецЕсли;

	Возврат Формат(ДатаДокумента, ФорматДаты);
КонецФункции

Функция РазобратьДатуСреза(ЗначDate, КонтекстДаты, МассивОшибок)
	ДатаСреза = КонецДня(ТекущаяДатаСеанса());

	Если ЗначDate = "" Тогда
		Возврат ДатаСреза;
	КонецЕсли;

	П = РазобратьДатуСтрокой(
		ЗначDate,
		КонтекстДаты.КолЧастейДаты,
		КонтекстДаты.ДлинаГода,
		КонтекстДаты.ДлинаМесяца,
		КонтекстДаты.ДлинаДня);
	Если П.Ок Тогда
		Возврат КонецДня(ДатаИзРазбора(П));
	КонецЕсли;

	МассивОшибок.Добавить("Некорректный параметр date: " + ЗначDate);
	Возврат ДатаСреза;
КонецФункции

Функция СовпадаетПостФильтр(ЗначениеПоля, Подстрока)
	Возврат СтрНайти(ВРег(Строка(ЗначениеПоля)), ВРег(Подстрока)) > 0;
КонецФункции

Функция ПроходитСтроковыйПостФильтр(ИспользоватьФильтр, ЗначениеПоля, Подстрока)
	Если Не ИспользоватьФильтр Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат СовпадаетПостФильтр(ЗначениеПоля, Подстрока);
КонецФункции

Функция СобратьФильтры(Запрос, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок)
	Фильтры = Новый Структура;
	КонтекстДаты = Новый Структура;
	КонтекстДаты.Вставить("КолЧастейДаты", КолЧастейДаты);
	КонтекстДаты.Вставить("ДлинаГода", ДлинаГода);
	КонтекстДаты.Вставить("ДлинаМесяца", ДлинаМесяца);
	КонтекстДаты.Вставить("ДлинаДня", ДлинаДня);

	ЗначDate = ПолучитьСтроковойПараметр(Запрос, "date");
	ДатаСреза = РазобратьДатуСреза(ЗначDate, КонтекстДаты, МассивОшибок);
	Фильтры.Вставить("ДатаСреза", ДатаСреза);
	Фильтры.Вставить("ДатаСрезаСтрокой", СтрокаДатыДокумента(ДатаСреза));

	ЗначCode = ПолучитьСтроковойПараметр(Запрос, "code");
	Фильтры.Вставить("ИспользоватьФильтрКод", ЗначCode <> "");
	Фильтры.Вставить("КодШаблон", ?(ЗначCode <> "", "%" + ЗначCode + "%", "%"));

	ЗначName = ПолучитьСтроковойПараметр(Запрос, "name");
	ЗначName = СтрЗаменить(ЗначName, "_slash_", "/");
	Фильтры.Вставить("ИспользоватьФильтрНаименование", ЗначName <> "");
	Фильтры.Вставить("НаименованиеШаблон", ?(ЗначName <> "", "%" + ЗначName + "%", "%"));

	ЗначWarehouse = ПолучитьСтроковойПараметр(Запрос, "warehouse");
	Фильтры.Вставить("ИспользоватьФильтрСклад", ЗначWarehouse <> "");
	Фильтры.Вставить("СкладШаблон", ?(ЗначWarehouse <> "", "%" + ЗначWarehouse + "%", "%"));
	Фильтры.Вставить("ПодстрокаСклад", ЗначWarehouse);

	ЗначFull = "";
	ИменаПараметраFull = СтрРазделить("full|Full|FULL", "|");
	Для Каждого ИмяПараметраFull Из ИменаПараметраFull Цикл
		ЗначFull = ПолучитьСтроковойПараметр(Запрос, ИмяПараметраFull);
		Если ЗначFull <> "" Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Фильтры.Вставить("ПолныйОтвет", ПреобразоватьВБулево(ЗначFull));

	Возврат Фильтры;
КонецФункции

Функция ТекстУсловияГдеОстатков(Фильтры)
	УсловияГде = "";

	Если Не Фильтры.ПолныйОтвет Тогда
		УсловияГде = УсловияГде + "
			|	И Партии.КоличествоОстаток <> 0";
	КонецЕсли;

	Возврат УсловияГде;
КонецФункции

Процедура УстановитьПараметрыЗапросаОстатков(ЗапросБД, Фильтры)
	ЗапросБД.УстановитьПараметр("ДатаСреза", Фильтры.ДатаСреза);
	ЗапросБД.УстановитьПараметр("КодШаблон", Фильтры.КодШаблон);
	ЗапросБД.УстановитьПараметр("НаименованиеШаблон", Фильтры.НаименованиеШаблон);
	ЗапросБД.УстановитьПараметр("СкладШаблон", Фильтры.СкладШаблон);
КонецПроцедуры

Функция ТекстЗапросаСтоимостиОстатков(УсловияГде)
	Возврат
	"ВЫБРАТЬ
	|	Партии.Номенклатура КАК Номенклатура,
	|	Партии.Склад КАК СкладСсылка,
	|	ПРЕДСТАВЛЕНИЕ(Партии.Склад) КАК Склад,
	|	СУММА(Партии.КоличествоОстаток) КАК Количество,
	|	СУММА(Партии.СтоимостьОстаток) КАК Стоимость
	|ИЗ
	|	РегистрНакопления.ПартииТоваровНаСкладах.Остатки(
	|			&ДатаСреза,
	|			Номенклатура В (
	|				ВЫБРАТЬ
	|					НомУсловия.Ссылка КАК Ссылка
	|				ИЗ
	|					Справочник.Номенклатура КАК НомУсловия
	|				ГДЕ
	|					НЕ НомУсловия.ПометкаУдаления
	|					И НЕ НомУсловия.ЭтоГруппа
	|					И НомУсловия.Код ПОДОБНО &КодШаблон
	|					И НомУсловия.Наименование ПОДОБНО &НаименованиеШаблон)
	|			И Склад В (
	|				ВЫБРАТЬ
	|					СкладыУсловия.Ссылка КАК Ссылка
	|				ИЗ
	|					Справочник.Склады КАК СкладыУсловия
	|				ГДЕ
	|					СкладыУсловия.Наименование ПОДОБНО &СкладШаблон)) КАК Партии
	|ГДЕ
	|	1 = 1"
	+ УсловияГде + "
	|
	|СГРУППИРОВАТЬ ПО
	|	Партии.Номенклатура,
	|	Партии.Склад
	|
	|УПОРЯДОЧИТЬ ПО
	|	Партии.Номенклатура,
	|	Склад";
КонецФункции

Функция ПолучитьВыборкуСтоимостиОстатков(Фильтры)
	ЗапросБД = Новый Запрос;
	УсловияГде = ТекстУсловияГдеОстатков(Фильтры);
	ЗапросБД.Текст = ТекстЗапросаСтоимостиОстатков(УсловияГде);
	УстановитьПараметрыЗапросаОстатков(ЗапросБД, Фильтры);

	Возврат ЗапросБД.Выполнить().Выбрать();
КонецФункции

Функция ТекстУсловияГдеНоменклатуры(Фильтры)
	УсловияГде = "";

	Если Фильтры.ИспользоватьФильтрКод Тогда
		УсловияГде = УсловияГде + "
			|	И Ном.Код ПОДОБНО &КодШаблон";
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрНаименование Тогда
		УсловияГде = УсловияГде + "
			|	И Ном.Наименование ПОДОБНО &НаименованиеШаблон";
	КонецЕсли;

	Возврат УсловияГде;
КонецФункции

Процедура УстановитьПараметрыЗапросаНоменклатуры(ЗапросБД, Фильтры)
	ЗапросБД.УстановитьПараметр("КодШаблон", Фильтры.КодШаблон);
	ЗапросБД.УстановитьПараметр("НаименованиеШаблон", Фильтры.НаименованиеШаблон);
КонецПроцедуры

Функция ТекстЗапросаНоменклатуры(УсловияГде)
	Возврат
	"ВЫБРАТЬ
	|	Ном.Ссылка КАК Номенклатура,
	|	Ном.Код КАК Код,
	|	Ном.Наименование КАК Наименование,
	|	ПРЕДСТАВЛЕНИЕ(Ном.БазоваяЕдиницаИзмерения) КАК ЕдиницаИзмерения,
	|	ПРЕДСТАВЛЕНИЕ(Ном.ВидНоменклатуры) КАК ВидНоменклатуры,
	|	ПРЕДСТАВЛЕНИЕ(Ном.НоменклатурнаяГруппа) КАК НоменклатурнаяГруппа
	|ИЗ
	|	Справочник.Номенклатура КАК Ном
	|ГДЕ
	|	НЕ Ном.ПометкаУдаления
	|	И НЕ Ном.ЭтоГруппа"
	+ УсловияГде + "
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";
КонецФункции

Функция ПолучитьВыборкуНоменклатуры(Фильтры)
	ЗапросБД = Новый Запрос;
	УсловияГде = ТекстУсловияГдеНоменклатуры(Фильтры);
	ЗапросБД.Текст = ТекстЗапросаНоменклатуры(УсловияГде);
	УстановитьПараметрыЗапросаНоменклатуры(ЗапросБД, Фильтры);

	Возврат ЗапросБД.Выполнить().Выбрать();
КонецФункции

Функция ЧислоДляОтвета(ЗначениеЧисла)
	Если ЗначениеЧисла = Неопределено Тогда
		Возврат 0;
	КонецЕсли;

	Возврат ЗначениеЧисла;
КонецФункции

Функция СредняяЦена(Количество, Стоимость)
	ТочностьЦены = СтрДлина("0000");

	Если Количество = 0 Тогда
		Возврат 0;
	КонецЕсли;

	Возврат Окр(Стоимость / Количество, ТочностьЦены);
КонецФункции

Функция КлючНоменклатурыИзВыборки(Выборка)
	Попытка
		Возврат Строка(Выборка.Номенклатура.УникальныйИдентификатор());
	Исключение
		Возврат Строка(Выборка.Номенклатура);
	КонецПопытки;
КонецФункции

Функция НоваяПозицияНоменклатуры(Выборка, Фильтры)
	НоменклатураСсылка = Выборка.Номенклатура;

	Попытка
		Код = Строка(НоменклатураСсылка.Код);
	Исключение
		Код = "";
	КонецПопытки;

	Попытка
		Наименование = Строка(НоменклатураСсылка.Наименование);
	Исключение
		Наименование = Строка(НоменклатураСсылка);
	КонецПопытки;

	Попытка
		ЕдиницаИзмерения = Строка(НоменклатураСсылка.БазоваяЕдиницаИзмерения);
	Исключение
		ЕдиницаИзмерения = "";
	КонецПопытки;

	Попытка
		ВидНоменклатуры = Строка(НоменклатураСсылка.ВидНоменклатуры);
	Исключение
		ВидНоменклатуры = "";
	КонецПопытки;

	Попытка
		НоменклатурнаяГруппа = Строка(НоменклатураСсылка.НоменклатурнаяГруппа);
	Исключение
		НоменклатурнаяГруппа = "";
	КонецПопытки;

	Позиция = Новый Структура;
	Позиция.Вставить("Код", Код);
	Позиция.Вставить("Наименование", Наименование);
	Позиция.Вставить("ЕдиницаИзмерения", ЕдиницаИзмерения);
	Позиция.Вставить("ВидНоменклатуры", ВидНоменклатуры);
	Позиция.Вставить("НоменклатурнаяГруппа", НоменклатурнаяГруппа);
	Позиция.Вставить("ДатаСреза", Фильтры.ДатаСрезаСтрокой);
	Позиция.Вставить("ИтогоКоличество", 0);
	Позиция.Вставить("ИтогоСтоимость", 0);
	Позиция.Вставить("СредняяЦена", 0);
	Позиция.Вставить("Остатки", Новый Массив);

	Возврат Позиция;
КонецФункции

Функция СформироватьСтрокуОстатка(Выборка)
	Количество = ЧислоДляОтвета(Выборка.Количество);
	Стоимость = ЧислоДляОтвета(Выборка.Стоимость);

	СтрокаОстатка = Новый Структура;
	СтрокаОстатка.Вставить("Склад", Строка(Выборка.Склад));
	СтрокаОстатка.Вставить("Количество", Количество);
	СтрокаОстатка.Вставить("Стоимость", Стоимость);
	СтрокаОстатка.Вставить("СредняяЦена", СредняяЦена(Количество, Стоимость));

	Возврат СтрокаОстатка;
КонецФункции

Процедура ДобавитьСтрокуОстаткаВПозицию(Позиция, СтрокаОстатка)
	Позиция.Остатки.Добавить(СтрокаОстатка);
	Позиция.ИтогоКоличество = Позиция.ИтогоКоличество + СтрокаОстатка.Количество;
	Позиция.ИтогоСтоимость = Позиция.ИтогоСтоимость + СтрокаОстатка.Стоимость;
	Позиция.СредняяЦена = СредняяЦена(Позиция.ИтогоКоличество, Позиция.ИтогоСтоимость);
КонецПроцедуры

Функция ПолучитьИлиСоздатьПозицию(Выборка, Фильтры, МассивОстатков, ИндексПоНоменклатуре)
	КлючНоменклатуры = КлючНоменклатурыИзВыборки(Выборка);
	Позиция = ИндексПоНоменклатуре.Получить(КлючНоменклатуры);

	Если Позиция = Неопределено Тогда
		Позиция = НоваяПозицияНоменклатуры(Выборка, Фильтры);
		ИндексПоНоменклатуре.Вставить(КлючНоменклатуры, Позиция);
		МассивОстатков.Добавить(Позиция);
	КонецЕсли;

	Возврат Позиция;
КонецФункции

Функция ОстатокПроходитПостФильтры(Выборка, Фильтры)
	Возврат ПроходитСтроковыйПостФильтр(
		Фильтры.ИспользоватьФильтрСклад,
		Выборка.Склад,
		Фильтры.ПодстрокаСклад);
КонецФункции

Процедура СобратьМассивОстатковИзВыборки(Выборка, Фильтры, МассивОстатков, ИндексПоНоменклатуре)
	Пока Выборка.Следующий() Цикл
		Если Не ОстатокПроходитПостФильтры(Выборка, Фильтры) Тогда
			Продолжить;
		КонецЕсли;

		Позиция = ПолучитьИлиСоздатьПозицию(Выборка, Фильтры, МассивОстатков, ИндексПоНоменклатуре);
		СтрокаОстатка = СформироватьСтрокуОстатка(Выборка);
		ДобавитьСтрокуОстаткаВПозицию(Позиция, СтрокаОстатка);
	КонецЦикла;
КонецПроцедуры

Процедура ДобавитьПозицииНоменклатурыИзВыборки(Выборка, Фильтры, МассивОстатков, ИндексПоНоменклатуре)
	Пока Выборка.Следующий() Цикл
		КлючНоменклатуры = КлючНоменклатурыИзВыборки(Выборка);
		Позиция = ИндексПоНоменклатуре.Получить(КлючНоменклатуры);

		Если Позиция = Неопределено Тогда
			Позиция = НоваяПозицияНоменклатуры(Выборка, Фильтры);
			ИндексПоНоменклатуре.Вставить(КлючНоменклатуры, Позиция);
			МассивОстатков.Добавить(Позиция);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция ОстатокСериализуетсяВJSON(Остаток)
	Попытка
		ТестоваяЗаписьJSON = Новый ЗаписьJSON;
		ТестоваяЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ТестоваяЗаписьJSON, Остаток);
		ТестоваяЗаписьJSON.Закрыть();
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
КонецФункции

Процедура УдалитьНесериализуемыеОстатки(МассивОстатков, МассивОшибок)
	Индекс = МассивОстатков.Количество() - 1;

	Пока Индекс >= 0 Цикл
		Остаток = МассивОстатков[Индекс];
		Если Не ОстатокСериализуетсяВJSON(Остаток) Тогда
			МассивОшибок.Добавить("Ошибка сериализации остатка: " + Остаток.Наименование);
			МассивОстатков.Удалить(Индекс);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
КонецПроцедуры

Функция СоздатьУспешныйОтвет(МассивОстатков, МассивОшибок)
	HTTPСтатусУспеха = 200;
	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data", МассивОстатков);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	JSON = Новый ЗаписьJSON;
	JSON.УстановитьСтроку();
	ЗаписатьJSON(JSON, ИтоговыйРезультат);
	JSONСтрока = JSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(HTTPСтатусУспеха);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(JSONСтрока);
	Возврат Ответ;
КонецФункции

Функция СоздатьОтветОшибки(ТекстОшибки)
	HTTPСтатусВнутренняяОшибкаСервера = 500;
	ДанныеОшибки = Новый Структура("error", ТекстОшибки);
	JSONОшибки = Новый ЗаписьJSON;
	JSONОшибки.УстановитьСтроку();
	ЗаписатьJSON(JSONОшибки, ДанныеОшибки);

	Ответ = Новый HTTPСервисОтвет(HTTPСтатусВнутренняяОшибкаСервера);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
	Возврат Ответ;
КонецФункции

Функция GetStockBalances_Impl(Запрос)
	МассивОстатков = Новый Массив;
	МассивОшибок = Новый Массив;
	КолЧастейДаты = СтрДлина("000");
	ДлинаГода = СтрДлина("0000");
	ДлинаМесяца = СтрДлина("00");
	ДлинаДня = СтрДлина("00");

	Попытка
		Фильтры = СобратьФильтры(Запрос, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок);
		ИндексПоНоменклатуре = Новый Соответствие;

		Если Фильтры.ПолныйОтвет Тогда
			ВыборкаНоменклатуры = ПолучитьВыборкуНоменклатуры(Фильтры);
			ДобавитьПозицииНоменклатурыИзВыборки(
				ВыборкаНоменклатуры,
				Фильтры,
				МассивОстатков,
				ИндексПоНоменклатуре);
		КонецЕсли;

		Выборка = ПолучитьВыборкуСтоимостиОстатков(Фильтры);
		СобратьМассивОстатковИзВыборки(Выборка, Фильтры, МассивОстатков, ИндексПоНоменклатуре);
		УдалитьНесериализуемыеОстатки(МассивОстатков, МассивОшибок);

		Возврат СоздатьУспешныйОтвет(МассивОстатков, МассивОшибок);
	Исключение
		Возврат СоздатьОтветОшибки(ОписаниеОшибки());
	КонецПопытки;
КонецФункции
