// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Поступление товаров и услуг. В JSON у каждого поступления: Номер, ДатаДокумента, Контрагент,
// Организация, Склад, Ответственный, СуммаДокумента, Комментарий; при full - Сделка, ТЧ Товары,
// ТЧ Услуги, Вложения.
// Параметры: from, to; code; date; contractor/contactor/supplier, org, warehouse, responsible; summ; approved; full.

Функция GetReceipts(Запрос) Экспорт
	Возврат GetReceipts_Impl(Запрос);
КонецФункции

Функция ПолучитьСтроковойПараметр(Запрос, ИмяПараметра)
	Значение = "";

	Попытка
		Значение = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить(ИмяПараметра)));
	Исключение
		Значение = "";
	КонецПопытки;

	Если Значение = "" Тогда
		Попытка
			Значение = СокрЛП(Строка(Запрос.ПараметрыURL[ИмяПараметра]));
		Исключение
			Значение = "";
		КонецПопытки;
	КонецЕсли;

	Возврат Значение;
КонецФункции

Функция ПреобразоватьВБулево(СтрокаЛог)
	Если ПустаяСтрока(СтрокаЛог) Тогда
		Возврат Ложь;
	КонецЕсли;

	Стр = ВРег(СокрЛП(СтрокаЛог));
	Возврат Стр = "1" Или Стр = "TRUE" Или Стр = "YES" Или Стр = "ДА";
КонецФункции

Функция РазобратьДатуСтрокой(ЗначДата, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня)
	Результат = Новый Структура;
	Результат.Вставить("Ок", Ложь);
	Результат.Вставить("Г", "");
	Результат.Вставить("М", "");
	Результат.Вставить("Д", "");

	Если Не ЗначениеЗаполнено(ЗначДата) Тогда
		Возврат Результат;
	КонецЕсли;

	Г = "";
	М = "";
	Д = "";
	ЧастиТочка = СтрРазделить(ЗначДата, ".", Ложь);
	ЧастиДефис = СтрРазделить(ЗначДата, "-", Ложь);

	Если ЧастиТочка.Количество() = КолЧастейДаты Тогда
		Д = ЧастиТочка[0];
		М = ЧастиТочка[1];
		Г = ЧастиТочка[2];
	ИначеЕсли ЧастиДефис.Количество() = КолЧастейДаты Тогда
		Если СтрДлина(СокрЛП(ЧастиДефис[0])) = ДлинаГода Тогда
			Г = ЧастиДефис[0];
			М = ЧастиДефис[1];
			Д = ЧастиДефис[2];
		Иначе
			Д = ЧастиДефис[0];
			М = ЧастиДефис[1];
			Г = ЧастиДефис[2];
		КонецЕсли;
	Иначе
		Возврат Результат;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Г) Тогда
		Возврат Результат;
	КонецЕсли;

	Пока СтрДлина(Г) < ДлинаГода Цикл
		Г = "0" + Г;
	КонецЦикла;
	Пока СтрДлина(М) < ДлинаМесяца Цикл
		М = "0" + М;
	КонецЦикла;
	Пока СтрДлина(Д) < ДлинаДня Цикл
		Д = "0" + Д;
	КонецЦикла;

	Результат.Вставить("Ок", Истина);
	Результат.Вставить("Г", Г);
	Результат.Вставить("М", М);
	Результат.Вставить("Д", Д);
	Возврат Результат;
КонецФункции

Функция РазобратьПериодFromTo(ЗначFrom, ЗначTo, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок)
	ПериодРезультат = Новый Структура;
	ПериодРезультат.Вставить("ИспользоватьПериод", Ложь);
	ПериодРезультат.Вставить("ДатаНачала", Дата(1, 1, 1));
	ПериодРезультат.Вставить("ДатаОкончания", Дата(1, 1, 1));

	Если Не ЗначениеЗаполнено(ЗначFrom) Или Не ЗначениеЗаполнено(ЗначTo) Тогда
		Возврат ПериодРезультат;
	КонецЕсли;

	П1 = РазобратьДатуСтрокой(ЗначFrom, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
	П2 = РазобратьДатуСтрокой(ЗначTo, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
	Если П1.Ок И П2.Ок Тогда
		ПериодРезультат.ДатаНачала = Дата(П1.Г + П1.М + П1.Д + "000000");
		ПериодРезультат.ДатаОкончания = КонецДня(Дата(П2.Г + П2.М + П2.Д + "000000"));
		ПериодРезультат.ИспользоватьПериод = Истина;
	Иначе
		МассивОшибок.Добавить("Некорректный формат from/to: " + ЗначFrom + " / " + ЗначTo);
	КонецЕсли;

	Возврат ПериодРезультат;
КонецФункции

Функция ПохожеНаЧисло(СтрокаЧисло)
	Если СтрокаЧисло = "" Тогда
		Возврат Ложь;
	КонецЕсли;

	ТекстЧисла = СтрЗаменить(СтрокаЧисло, ",", ".");
	ЕстьТочка = Ложь;
	Для Индекс = 1 По СтрДлина(ТекстЧисла) Цикл
		Символ = Сред(ТекстЧисла, Индекс, 1);
		Если Символ = "." Тогда
			Если ЕстьТочка Тогда
				Возврат Ложь;
			КонецЕсли;
			ЕстьТочка = Истина;
		ИначеЕсли Символ >= "0" И Символ <= "9" Тогда
			Продолжить;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;

	Возврат Истина;
КонецФункции

Функция СовпадаетПостФильтр(ЗначениеПоля, Подстрока)
	Возврат СтрНайти(ВРег(Строка(ЗначениеПоля)), ВРег(Подстрока)) > 0;
КонецФункции

Функция ПроходитСтроковыйПостФильтр(ИспользоватьФильтр, ЗначениеПоля, Подстрока)
	Если Не ИспользоватьФильтр Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат СовпадаетПостФильтр(ЗначениеПоля, Подстрока);
КонецФункции

Функция СобратьФильтры(Запрос, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок)
	Фильтры = Новый Структура;
	ПараметрПолныйНижний = "full";
	ПараметрПолныйВерхний = ВРег(ПараметрПолныйНижний);
	ПозицияНачалаОстатка = 2;
	ПараметрПолныйСЗаглавной = ВРег(Лев(ПараметрПолныйНижний, 1))
		+ Сред(ПараметрПолныйНижний, ПозицияНачалаОстатка, СтрДлина(ПараметрПолныйНижний) - 1);

	ЗначFrom = ПолучитьСтроковойПараметр(Запрос, "from");
	ЗначTo = ПолучитьСтроковойПараметр(Запрос, "to");
	ПериодРезультат = РазобратьПериодFromTo(
		ЗначFrom,
		ЗначTo,
		КолЧастейДаты,
		ДлинаГода,
		ДлинаМесяца,
		ДлинаДня,
		МассивОшибок);
	Фильтры.Вставить("ИспользоватьПериод", ПериодРезультат.ИспользоватьПериод);
	Фильтры.Вставить("ДатаНачала", ПериодРезультат.ДатаНачала);
	Фильтры.Вставить("ДатаОкончания", ПериодРезультат.ДатаОкончания);

	ЗначCode = ПолучитьСтроковойПараметр(Запрос, "code");
	Фильтры.Вставить("ИспользоватьФильтрНомер", ЗначCode <> "");
	Фильтры.Вставить("НомерШаблон", ?(ЗначCode <> "", "%" + ЗначCode + "%", "%"));

	ИспользоватьФильтрДата = Ложь;
	ДатаФильтр = Дата(1, 1, 1);
	ДатаФильтрКонец = Дата(1, 1, 1);
	ЗначDate = ПолучитьСтроковойПараметр(Запрос, "date");
	Если ЗначDate <> "" Тогда
		П = РазобратьДатуСтрокой(ЗначDate, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
		Если П.Ок Тогда
			ДатаФильтр = Дата(П.Г + П.М + П.Д + "000000");
			ДатаФильтрКонец = КонецДня(ДатаФильтр);
			ИспользоватьФильтрДата = Истина;
		Иначе
			МассивОшибок.Добавить("Некорректный параметр date: " + ЗначDate);
		КонецЕсли;
	КонецЕсли;
	Фильтры.Вставить("ИспользоватьФильтрДата", ИспользоватьФильтрДата);
	Фильтры.Вставить("ДатаФильтр", ДатаФильтр);
	Фильтры.Вставить("ДатаФильтрКонец", ДатаФильтрКонец);

	ЗначSumm = ПолучитьСтроковойПараметр(Запрос, "summ");
	Фильтры.Вставить("ИспользоватьФильтрСумма", ПохожеНаЧисло(ЗначSumm));
	Фильтры.Вставить("СуммаФильтр", ?(ПохожеНаЧисло(ЗначSumm), Число(ЗначSumm), 0));

	ЗначApproved = ПолучитьСтроковойПараметр(Запрос, "approved");
	Фильтры.Вставить("ИспользоватьФильтрПроведен", ЗначApproved <> "");
	Фильтры.Вставить("ПроведенФильтр", ПреобразоватьВБулево(ЗначApproved));

	ЗначПолный = ПолучитьСтроковойПараметр(Запрос, ПараметрПолныйНижний);
	Если ЗначПолный = "" Тогда
		ЗначПолный = ПолучитьСтроковойПараметр(Запрос, ПараметрПолныйСЗаглавной);
	КонецЕсли;
	Если ЗначПолный = "" Тогда
		ЗначПолный = ПолучитьСтроковойПараметр(Запрос, ПараметрПолныйВерхний);
	КонецЕсли;
	Фильтры.Вставить("ПолныйОтвет", ПреобразоватьВБулево(ЗначПолный));

	ЗначContractor = ПолучитьСтроковойПараметр(Запрос, "contractor");
	Если ЗначContractor = "" Тогда
		ЗначContractor = ПолучитьСтроковойПараметр(Запрос, "contactor");
	КонецЕсли;
	Если ЗначContractor = "" Тогда
		ЗначContractor = ПолучитьСтроковойПараметр(Запрос, "supplier");
	КонецЕсли;
	Фильтры.Вставить("ИспользоватьФильтрКонтрагент", ЗначContractor <> "");
	Фильтры.Вставить("ПодстрокаКонтрагент", ЗначContractor);

	ЗначOrg = ПолучитьСтроковойПараметр(Запрос, "org");
	Фильтры.Вставить("ИспользоватьФильтрОрганизация", ЗначOrg <> "");
	Фильтры.Вставить("ПодстрокаОрганизация", ЗначOrg);

	ЗначWarehouse = ПолучитьСтроковойПараметр(Запрос, "warehouse");
	Фильтры.Вставить("ИспользоватьФильтрСклад", ЗначWarehouse <> "");
	Фильтры.Вставить("ПодстрокаСклад", ЗначWarehouse);

	ЗначResponsible = ПолучитьСтроковойПараметр(Запрос, "responsible");
	Фильтры.Вставить("ИспользоватьФильтрОтветственный", ЗначResponsible <> "");
	Фильтры.Вставить("ПодстрокаОтветственный", ЗначResponsible);

	Возврат Фильтры;
КонецФункции

Функция ПроходитПостФильтры(Выборка, Фильтры)
	Возврат
		ПроходитСтроковыйПостФильтр(
			Фильтры.ИспользоватьФильтрКонтрагент,
			Выборка.Контрагент,
			Фильтры.ПодстрокаКонтрагент)
		И ПроходитСтроковыйПостФильтр(
			Фильтры.ИспользоватьФильтрОрганизация,
			Выборка.Организация,
			Фильтры.ПодстрокаОрганизация)
		И ПроходитСтроковыйПостФильтр(Фильтры.ИспользоватьФильтрСклад, Выборка.Склад, Фильтры.ПодстрокаСклад)
		И ПроходитСтроковыйПостФильтр(
			Фильтры.ИспользоватьФильтрОтветственный,
			Выборка.Ответственный,
			Фильтры.ПодстрокаОтветственный);
КонецФункции

Функция ПолучитьВыборкуПоступлений(Фильтры)
	ЗапросБД = Новый Запрос;
	УсловияГде = "";

	Если Фильтры.ИспользоватьПериод Тогда
		УсловияГде = УсловияГде + "
			|	И ПТУ.Дата >= &ДатаНачала
			|	И ПТУ.Дата <= &ДатаОкончания";
	КонецЕсли;
	Если Фильтры.ИспользоватьФильтрНомер Тогда
		УсловияГде = УсловияГде + "
			|	И ПТУ.Номер ПОДОБНО &НомерШаблон";
	КонецЕсли;
	Если Фильтры.ИспользоватьФильтрДата Тогда
		УсловияГде = УсловияГде + "
			|	И ПТУ.Дата >= &ДатаФильтр
			|	И ПТУ.Дата <= &ДатаФильтрКонец";
	КонецЕсли;
	Если Фильтры.ИспользоватьФильтрСумма Тогда
		УсловияГде = УсловияГде + "
			|	И ПТУ.СуммаДокумента = &СуммаФильтр";
	КонецЕсли;
	Если Фильтры.ИспользоватьФильтрПроведен Тогда
		УсловияГде = УсловияГде + "
			|	И ПТУ.Проведен = &ПроведенФильтр";
	КонецЕсли;

	ЗапросБД.Текст =
	"ВЫБРАТЬ
	|	ПТУ.Ссылка КАК Ссылка,
	|	ПТУ.Номер КАК Номер,
	|	ПТУ.Дата КАК ДатаДокумента,
	|	ПТУ.Сделка КАК Сделка,
	|	ПРЕДСТАВЛЕНИЕ(ПТУ.Контрагент) КАК Контрагент,
	|	ПРЕДСТАВЛЕНИЕ(ПТУ.Организация) КАК Организация,
	|	ПРЕДСТАВЛЕНИЕ(ПТУ.СкладОрдер) КАК Склад,
	|	ПРЕДСТАВЛЕНИЕ(ПТУ.Ответственный) КАК Ответственный,
	|	ПТУ.СуммаДокумента КАК СуммаДокумента,
	|	ПТУ.Проведен КАК Проведен,
	|	ПТУ.Комментарий КАК Комментарий
	|ИЗ
	|	Документ.ПоступлениеТоваровУслуг КАК ПТУ
	|ГДЕ
	|	1 = 1"
	+ УсловияГде
	+ "
	|УПОРЯДОЧИТЬ ПО
	|	ПТУ.Дата УБЫВ, ПТУ.Номер УБЫВ";

	ЗапросБД.УстановитьПараметр("ДатаНачала", Фильтры.ДатаНачала);
	ЗапросБД.УстановитьПараметр("ДатаОкончания", Фильтры.ДатаОкончания);
	ЗапросБД.УстановитьПараметр("НомерШаблон", Фильтры.НомерШаблон);
	ЗапросБД.УстановитьПараметр("ДатаФильтр", Фильтры.ДатаФильтр);
	ЗапросБД.УстановитьПараметр("ДатаФильтрКонец", Фильтры.ДатаФильтрКонец);
	ЗапросБД.УстановитьПараметр("СуммаФильтр", Фильтры.СуммаФильтр);
	ЗапросБД.УстановитьПараметр("ПроведенФильтр", Фильтры.ПроведенФильтр);

	Возврат ЗапросБД.Выполнить().Выбрать();
КонецФункции

Функция СтрокаДатыДокумента(ДатаДокумента)
	Если Не ЗначениеЗаполнено(ДатаДокумента) Тогда
		Возврат "";
	КонецЕсли;

	Возврат Формат(ДатаДокумента, "ДФ=dd.MM.yyyy");
КонецФункции

Функция ТекстПоляИлиЗаглушка(Значение, Заглушка)
	Если Не ЗначениеЗаполнено(Значение) Тогда
		Возврат Заглушка;
	КонецЕсли;

	Возврат Значение;
КонецФункции

Функция СуммаДокументаДляОтвета(СуммаДокумента)
	Если ПустаяСтрока(Строка(СуммаДокумента)) Или СуммаДокумента = Неопределено Тогда
		Возврат 0;
	КонецЕсли;

	Возврат СуммаДокумента;
КонецФункции

Функция СформироватьСделкуПустую()
	СделкаСтр = Новый Структура;
	СделкаСтр.Вставить("Тип", "");
	СделкаСтр.Вставить("Номер", "");
	СделкаСтр.Вставить("Дата", "");
	СделкаСтр.Вставить("НомерДата", "");
	Возврат СделкаСтр;
КонецФункции

Функция СформироватьСделкуПолную(Выборка, МассивОшибок)
	Если Не ЗначениеЗаполнено(Выборка.Сделка) Тогда
		Возврат СформироватьСделкуПустую();
	КонецЕсли;

	СделкаСтр = Новый Структура;
	Попытка
		ДатаСд = СтрокаДатыДокумента(Выборка.Сделка.Дата);
		СделкаСтр.Вставить("Тип", Выборка.Сделка.Метаданные().Имя);
		СделкаСтр.Вставить("Номер", Выборка.Сделка.Номер);
		СделкаСтр.Вставить("Дата", ДатаСд);
		СделкаСтр.Вставить("НомерДата", Строка(Выборка.Сделка.Номер) + " от " + ДатаСд);
	Исключение
		МассивОшибок.Добавить(
			"Поступление №" + Выборка.Номер + ": не удалось прочитать Сделка - " + ОписаниеОшибки());
		СделкаСтр = СформироватьСделкуПустую();
	КонецПопытки;

	Возврат СделкаСтр;
КонецФункции

Функция НаименованиеСсылочногоПоля(Ссылка)
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Строка(Ссылка.Наименование);
	КонецЕсли;

	Возврат "";
КонецФункции

Функция СформироватьСтрокуТовара(СтрокаТЧ)
	Стр = Новый Структура;
	Стр.Вставить("НомерСтроки", Строка(СтрокаТЧ.НомерСтроки));
	Стр.Вставить("Номенклатура", НаименованиеСсылочногоПоля(СтрокаТЧ.Номенклатура));
	Стр.Вставить("ХарактеристикаНоменклатуры", НаименованиеСсылочногоПоля(СтрокаТЧ.ХарактеристикаНоменклатуры));
	Стр.Вставить("ЕдиницаИзмерения", НаименованиеСсылочногоПоля(СтрокаТЧ.ЕдиницаИзмерения));
	Стр.Вставить("Количество", СтрокаТЧ.Количество);
	Стр.Вставить("Цена", СтрокаТЧ.Цена);
	Стр.Вставить("Сумма", СтрокаТЧ.Сумма);
	Стр.Вставить("СтавкаНДС", Строка(СтрокаТЧ.СтавкаНДС));
	Стр.Вставить("СуммаНДС", СтрокаТЧ.СуммаНДС);
	Возврат Стр;
КонецФункции

Функция СформироватьСтрокуУслуги(СтрокаТЧ)
	Стр = Новый Структура;
	Стр.Вставить("НомерСтроки", Строка(СтрокаТЧ.НомерСтроки));
	Стр.Вставить("Содержание", Строка(СтрокаТЧ.Содержание));
	Стр.Вставить("Номенклатура", НаименованиеСсылочногоПоля(СтрокаТЧ.Номенклатура));
	Стр.Вставить("Количество", СтрокаТЧ.Количество);
	Стр.Вставить("Цена", СтрокаТЧ.Цена);
	Стр.Вставить("Сумма", СтрокаТЧ.Сумма);
	Стр.Вставить("СтавкаНДС", Строка(СтрокаТЧ.СтавкаНДС));
	Стр.Вставить("СуммаНДС", СтрокаТЧ.СуммаНДС);
	Возврат Стр;
КонецФункции

Функция СформироватьТоварыИУслуги(СсылкаПоступления, НомерПоступления, МассивОшибок)
	Результат = Новый Структура("Товары, Услуги", Новый Массив, Новый Массив);

	Попытка
		ОбъектПоступление = СсылкаПоступления.ПолучитьОбъект();
		Для Каждого СтрокаТЧ Из ОбъектПоступление.Товары Цикл
			Результат.Товары.Добавить(СформироватьСтрокуТовара(СтрокаТЧ));
		КонецЦикла;
		Для Каждого СтрокаТЧ Из ОбъектПоступление.Услуги Цикл
			Результат.Услуги.Добавить(СформироватьСтрокуУслуги(СтрокаТЧ));
		КонецЦикла;
	Исключение
		МассивОшибок.Добавить(
			"Поступление №" + НомерПоступления + ": ошибка чтения ТЧ Товары/Услуги - " + ОписаниеОшибки());
	КонецПопытки;

	Возврат Результат;
КонецФункции

Функция Base64ИзДвоичныхДанных(ДвоичныеДанные)
	Если ТипЗнч(ДвоичныеДанные) <> Тип("ДвоичныеДанные") Тогда
		Возврат "";
	КонецЕсли;
	Если ДвоичныеДанные.Размер() = 0 Тогда
		Возврат "";
	КонецЕсли;

	Попытка
		Возврат Строка(Base64Строка(ДвоичныеДанные));
	Исключение
		Возврат "";
	КонецПопытки;
КонецФункции

Функция СформироватьВложениеИзХДИ(ВыборкаХДИ, НомерПоступления, МассивОшибок)
	Попытка
		ЭлементХДИ = ВыборкаХДИ.Ссылка.ПолучитьОбъект();
		ДвоичныеДанные = Неопределено;
		Если ЗначениеЗаполнено(ЭлементХДИ.Хранилище) Тогда
			ДвоичныеДанные = ЭлементХДИ.Хранилище.Получить();
		КонецЕсли;

		Вложение = Новый Структура("ИмяФайла", ВыборкаХДИ.ИмяФайла);
		Вложение.Вставить("Данные", Base64ИзДвоичныхДанных(ДвоичныеДанные));
		Возврат Вложение;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ТекстСообщения = "Поступление №" + НомерПоступления + ": не удалось прочитать вложение """
			+ ВыборкаХДИ.ИмяФайла + """ - " + ТекстОшибки;
		МассивОшибок.Добавить(ТекстСообщения);
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

Функция ПолучитьВложенияПолные(СсылкаДокумента, НомерПоступления, МассивОшибок)
	МассивВложений = Новый Массив;
	ЗапросХДИ = Новый Запрос;
	ЗапросХДИ.Текст =
	"ВЫБРАТЬ
	|	ХДИ.Ссылка КАК Ссылка,
	|	ХДИ.ИмяФайла КАК ИмяФайла
	|ИЗ
	|	Справочник.ХранилищеДополнительнойИнформации КАК ХДИ
	|ГДЕ
	|	ХДИ.Объект = &СсылкаДокумента";
	ЗапросХДИ.УстановитьПараметр("СсылкаДокумента", СсылкаДокумента);

	Попытка
		ВыборкаХДИ = ЗапросХДИ.Выполнить().Выбрать();
		Пока ВыборкаХДИ.Следующий() Цикл
			Вложение = СформироватьВложениеИзХДИ(ВыборкаХДИ, НомерПоступления, МассивОшибок);
			Если Вложение <> Неопределено Тогда
				МассивВложений.Добавить(Вложение);
			КонецЕсли;
		КонецЦикла;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ТекстСообщения = "Поступление №" + НомерПоступления + ": ошибка запроса вложений - " + ТекстОшибки;
		МассивОшибок.Добавить(ТекстСообщения);
	КонецПопытки;

	Возврат МассивВложений;
КонецФункции

Функция ПолучитьКоличествоВложений(СсылкаДокумента)
	КоличествоВложений = 0;
	ЗапросХДИ = Новый Запрос;
	ЗапросХДИ.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(ХДИ.Ссылка) КАК Количество
	|ИЗ
	|	Справочник.ХранилищеДополнительнойИнформации КАК ХДИ
	|ГДЕ
	|	ХДИ.Объект = &СсылкаДокумента";
	ЗапросХДИ.УстановитьПараметр("СсылкаДокумента", СсылкаДокумента);

	Попытка
		ТХДИ = ЗапросХДИ.Выполнить().Выгрузить();
		Если ТХДИ.Количество() > 0 Тогда
			КоличествоВложений = ТХДИ[0].Количество;
		КонецЕсли;
	Исключение
		КоличествоВложений = 0;
	КонецПопытки;

	Возврат КоличествоВложений;
КонецФункции

Процедура ДобавитьПолныйОтветПоступления(Поступление, Выборка, МассивОшибок)
	Поступление.Вставить("Сделка", СформироватьСделкуПолную(Выборка, МассивОшибок));

	ТоварыИУслуги = СформироватьТоварыИУслуги(Выборка.Ссылка, Выборка.Номер, МассивОшибок);
	Поступление.Вставить("Товары", ТоварыИУслуги.Товары);
	Поступление.Вставить("Услуги", ТоварыИУслуги.Услуги);
	Поступление.Вставить("Вложения", ПолучитьВложенияПолные(Выборка.Ссылка, Выборка.Номер, МассивОшибок));
КонецПроцедуры

Процедура ДобавитьКраткийОтветПоступления(Поступление, Выборка)
	СделкаЕсть = ЗначениеЗаполнено(Выборка.Сделка);
	КоличествоВложений = ПолучитьКоличествоВложений(Выборка.Ссылка);
	КоличествоСделок = 0;
	Если СделкаЕсть Тогда
		КоличествоСделок = 1;
	КонецЕсли;

	Поступление.Вставить("Сделка", Новый Структура("Есть, Количество", СделкаЕсть, КоличествоСделок));
	Поступление.Вставить(
		"Вложения",
		Новый Структура("Есть, Количество", КоличествоВложений > 0, КоличествоВложений));
КонецПроцедуры

Функция ЗаполнитьШапкуПоступления(Выборка)
	Поступление = Новый Структура;
	СтрокаДаты = СтрокаДатыДокумента(Выборка.ДатаДокумента);
	ТекстНеУказан = "Не указан";
	ТекстНеУказана = "Не указана";

	Поступление.Вставить("Номер", Выборка.Номер);
	Поступление.Вставить("ДатаДокумента", СтрокаДаты);
	Поступление.Вставить("Дата", СтрокаДаты);
	Поступление.Вставить("Контрагент", ТекстПоляИлиЗаглушка(Выборка.Контрагент, ТекстНеУказан));
	Поступление.Вставить("Организация", ТекстПоляИлиЗаглушка(Выборка.Организация, ТекстНеУказана));
	Поступление.Вставить("Склад", ТекстПоляИлиЗаглушка(Выборка.Склад, ТекстНеУказан));
	Поступление.Вставить("Ответственный", ТекстПоляИлиЗаглушка(Выборка.Ответственный, ТекстНеУказан));
	Поступление.Вставить("СуммаДокумента", СуммаДокументаДляОтвета(Выборка.СуммаДокумента));
	Поступление.Вставить("Комментарий", ?(ЗначениеЗаполнено(Выборка.Комментарий), Выборка.Комментарий, ""));
	Поступление.Вставить("Проведен", Выборка.Проведен);

	Возврат Поступление;
КонецФункции

Функция СформироватьПоступлениеИзВыборки(Выборка, Фильтры, МассивОшибок)
	Поступление = ЗаполнитьШапкуПоступления(Выборка);

	Если Фильтры.ПолныйОтвет Тогда
		ДобавитьПолныйОтветПоступления(Поступление, Выборка, МассивОшибок);
	Иначе
		ДобавитьКраткийОтветПоступления(Поступление, Выборка);
	КонецЕсли;

	Возврат Поступление;
КонецФункции

Функция ПоступлениеСериализуетсяВJSON(Поступление)
	Попытка
		ТестоваяЗаписьJSON = Новый ЗаписьJSON;
		ТестоваяЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ТестоваяЗаписьJSON, Поступление);
		ТестоваяЗаписьJSON.Закрыть();
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
КонецФункции

Функция СоздатьУспешныйОтвет(МассивПоступлений, МассивОшибок)
	HTTPСтатусУспеха = 200;
	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data", МассивПоступлений);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	JSON = Новый ЗаписьJSON;
	JSON.УстановитьСтроку();
	ЗаписатьJSON(JSON, ИтоговыйРезультат);
	JSONСтрока = JSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(HTTPСтатусУспеха);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(JSONСтрока);
	Возврат Ответ;
КонецФункции

Функция СоздатьОтветОшибки(ТекстОшибки)
	HTTPСтатусВнутренняяОшибкаСервера = 500;
	ДанныеОшибки = Новый Структура("error", ТекстОшибки);
	JSONОшибки = Новый ЗаписьJSON;
	JSONОшибки.УстановитьСтроку();
	ЗаписатьJSON(JSONОшибки, ДанныеОшибки);

	Ответ = Новый HTTPСервисОтвет(HTTPСтатусВнутренняяОшибкаСервера);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
	Возврат Ответ;
КонецФункции

Функция GetReceipts_Impl(Запрос)
	МассивПоступлений = Новый Массив;
	МассивОшибок = Новый Массив;
	КолЧастейДаты = СтрДлина("000");
	ДлинаГода = СтрДлина("0000");
	ДлинаМесяца = СтрДлина("00");
	ДлинаДня = СтрДлина("00");

	Попытка
		Фильтры = СобратьФильтры(Запрос, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок);
		Выборка = ПолучитьВыборкуПоступлений(Фильтры);

		Пока Выборка.Следующий() Цикл
			Если Не ПроходитПостФильтры(Выборка, Фильтры) Тогда
				Продолжить;
			КонецЕсли;

			Поступление = СформироватьПоступлениеИзВыборки(Выборка, Фильтры, МассивОшибок);
			Если ПоступлениеСериализуетсяВJSON(Поступление) Тогда
				МассивПоступлений.Добавить(Поступление);
			Иначе
				СтрокаДатыПоступления = СтрокаДатыДокумента(Выборка.ДатаДокумента);
				ТекстОшибкиСериализации = "Проблема в поступлении №" + Выборка.Номер + " от "
					+ СтрокаДатыПоступления + ". Ошибка сериализации JSON.";
				МассивОшибок.Добавить(ТекстОшибкиСериализации);
			КонецЕсли;
		КонецЦикла;

		Возврат СоздатьУспешныйОтвет(МассивПоступлений, МассивОшибок);
	Исключение
		Возврат СоздатьОтветОшибки(ОписаниеОшибки());
	КонецПопытки;
КонецФункции
